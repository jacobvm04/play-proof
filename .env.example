# ─────────────────────────────────────────────────────────────
# PlayProof environment configuration
# Copy to .env.local and fill in. Never commit .env.local.
#
# TWO WAYS TO RUN:
#  • Local chain (no faucet needed): `npm run chain` then
#    `npm run deploy && npm run seed` (CHAIN defaults to local). The deploy
#    script auto-fills NEXT_PUBLIC_PLAYPROOF_CONTRACT. For the local chain set
#    NEXT_PUBLIC_OG_CHAIN_ID=31337, NEXT_PUBLIC_OG_RPC=http://127.0.0.1:8545,
#    and OG_SERVER_PRIVATE_KEY to the first funded local account
#    (printed by `npm run chain`, also in data/local-accounts.json).
#  • 0G Galileo testnet: fund OG_SERVER_PRIVATE_KEY via https://faucet.0g.ai,
#    then `CHAIN=0g npm run deploy && CHAIN=0g npm run seed`.
# ─────────────────────────────────────────────────────────────

# 0G Galileo Testnet (V3)  — or override with the local-chain values above
NEXT_PUBLIC_OG_CHAIN_ID=16602
NEXT_PUBLIC_OG_RPC=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_OG_EXPLORER=https://chainscan-galileo.0g.ai
NEXT_PUBLIC_OG_CURRENCY=OG

# 0G Storage indexer (Turbo network)
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
NEXT_PUBLIC_OG_STORAGE_EXPLORER=https://storagescan-galileo.0g.ai

# Server-side signer = the PlayProof ORACLE (posts AI pre-scores + finalizes) and
# the account that PAYS for 0G Storage uploads. On 0G it needs testnet funds from
# https://faucet.0g.ai; on the local chain use the first funded account.
OG_SERVER_PRIVATE_KEY=

# Deployed PlayProof contract address (auto-filled by `npm run deploy`)
NEXT_PUBLIC_PLAYPROOF_CONTRACT=

# ── 0G Compute Network (AI pre-screen + labeling) ──
# When set, the trace pre-screen routes through 0G Compute.
# When empty, it falls back to the deterministic local mock provider
# (the demo still works end-to-end, and the UI shows where Compute is called).
OG_COMPUTE_ENABLED=false
OG_COMPUTE_PROVIDER=
OG_COMPUTE_PRIVATE_KEY=
